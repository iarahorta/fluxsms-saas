{
  "name": "fluxsms-polo-worker",
  "version": "0.1.0",
  "private": true,
  "description": "FluxSMS Polo Worker — Electron + Partner API + COM",
  "author": "FluxSMS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w serialport",
    "dist": "electron-builder --win portable --publish never"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.2.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fluxsms.poloworker",
    "productName": "FluxSMS Polo Worker",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "src/**/*",
      "index.html",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": false
    }
  }
}
