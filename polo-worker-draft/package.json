{
  "name": "fluxsms-polo-worker",
  "version": "0.5.2",
  "private": true,
  "description": "FluxSMS Desktop — parceiros (Polo Worker + API + COM)",
  "author": "FluxSMS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w serialport",
    "dist": "electron-builder --win nsis --publish never",
    "prepare-core-runtime": "node scripts/prepare-core-runtime.js",
    "build-exe": "npm run prepare-core-runtime && npm run rebuild && npm run dist"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "electron-store": "^8.2.0",
    "node-machine-id": "^1.1.12",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fluxsms.poloworker",
    "productName": "FluxSMS Desktop",
    "artifactName": "FluxSMS.${version}.${ext}",
    "directories": {
      "output": "../public/download"
    },
    "asar": true,
    "files": [
      "src/**/*",
      "index.html",
      "package.json",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "core-v7.1-runtime",
        "to": "core-v7.1"
      }
    ],
    "win": {
      "icon": "../marketing/assets/fluxsms-chip-dourado.png",
      "executableName": "FluxSMS Desktop",
      "requestedExecutionLevel": "asInvoker",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": true,
      "include": "build/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "FluxSMS Desktop",
      "uninstallDisplayName": "FluxSMS Desktop",
      "runAfterFinish": true
    }
  }
}
