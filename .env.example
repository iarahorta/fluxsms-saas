# ============================================================
# FluxSMS - GitHub Secrets necessários
# Configure em: Settings → Secrets and variables → Actions
# ============================================================

# ─── SUPABASE ────────────────────────────────────────────────
# URL do projeto (ex: https://xyzabc.supabase.co)
SUPABASE_URL=

# Chave ANON (pública - usada no frontend com RLS)
SUPABASE_ANON_KEY=

# Chave SERVICE_ROLE (privada - NUNCA no frontend)
SUPABASE_SERVICE_KEY=
CHAT_WIDGET_PROVIDER=
CRISP_WEBSITE_ID=
TAWK_PROPERTY_ID=
TAWK_WIDGET_ID=
SUPPORT_EMAIL=suporte@fluxsms.com.br

# Token de acesso pessoal ao Supabase CLI
SUPABASE_ACCESS_TOKEN=

# ID do projeto Supabase (encontrado em Project Settings)
SUPABASE_PROJECT_ID=

# Senha do banco de dados Supabase
SUPABASE_DB_PASSWORD=

# Connection string Postgres (URI) — para scripts locais (ex.: apply-migration-011-pg.js)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@...pooler.supabase.com:6543/postgres

# ─── MERCADO PAGO ────────────────────────────────────────────
# Access Token da sua conta (começa com APP_USR-)
MP_ACCESS_TOKEN=

# ─── NEXUSPAG (PIX dinâmico — compatível com “Nexus Pay” / NexusPag) ───
# Nunca commite a API key. Configure no Railway / ambiente seguro.
# Documentação pública (referência): https://nexuspag.com/docs
NEXUSPAG_BASE_URL=https://nexuspag.com
NEXUSPAG_API_KEY=
# Token partilhado exigido no webhook de retorno (header x-webhook-token ou Bearer)
NEXUSPAG_WEBHOOK_TOKEN=
# Opcional: também aceita este nome de variável
# NEXUS_PAY_API_KEY=
# URL pública do site (webhook de confirmação)
PUBLIC_BASE_URL=https://fluxsms.com.br
# Opcional: após PIX Nexus pago, split interno nas virtual_wallets (default 60/13/13 + resto)
# NEXUS_DEPOSIT_PCT_PARCEIRO=0.6
# NEXUS_DEPOSIT_PCT_SOCIO=0.13
# NEXUS_DEPOSIT_PCT_IARA=0.13
# NEXUS_DEPOSIT_SLUG_PARCEIRO=CAIXA_CHIP
# NEXUS_DEPOSIT_SLUG_SOCIO=LUCRO_SOCIO
# NEXUS_DEPOSIT_SLUG_IARA=LUCRO_IARA
# NEXUS_DEPOSIT_SLUG_REST=LUCRO_JORSIA
# Debug: retorna payload bruto do gateway na criação do PIX (apenas dev)
# NEXUSPAG_DEBUG=1

# Custo estimado da Nexus por saque (PIX saída) — usado para calcular sobra p/ CAIXA_CHIP
NEXUS_WITHDRAWAL_COST_BRL=2

# ─── CLOUDFLARE ──────────────────────────────────────────────
# Token da API Cloudflare (com permissão Zone:Edit)
CF_API_TOKEN=

# Zone ID do seu domínio (em Overview do domínio no CF)
CF_ZONE_ID=

# Seu domínio
DOMAIN=fluxsms.com.br

# ─── HARDWARE / MODEM ────────────────────────────────────────
# Chave secreta que seu PC usa para enviar o SMS ao backend
# Gere uma chave forte: openssl rand -hex 32
HARDWARE_API_KEY=

# ─── APP DESKTOP PARCEIROS ───────────────────────────────────
# Opcional: URL absoluto do instalador (sobrepõe o link padrão /download/FluxSMS_Setup.exe)
# POLO_WORKER_DOWNLOAD_URL=https://fluxsms.com.br/download/FluxSMS_Setup.exe

# ─── DEPLOY ──────────────────────────────────────────────────
# Token do Railway para deploy do backend
RAILWAY_TOKEN=

# URL do frontend (para CORS no backend)
FRONTEND_URL=https://fluxsms.com.br

# Staging (Railway): define 1 para servir o index do portal parceiro em todo o host e activar /p/login.
# Simula parceiros.* sem DNS. Não use em produção do site cliente.
# FORCE_PARTNER_PORTAL=1

# Cadastro publico de parceiros (POST /api/partner/onboarding/activate + pagina /portal/register).
# Por defeito FECHADO no codigo se a variavel nao existir ou for diferente de 1.
# Para reabrir o fluxo autonomo: PUBLIC_PARTNER_REGISTER=1
# PUBLIC_PARTNER_REGISTER=1
